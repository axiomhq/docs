    "fumadocs-mdx": "15.2.0",
    "fumadocs-ui": "16.11.5",
    "hast-util-to-jsx-runtime": "2.3.6",
    "lucide-react": "1.24.0",
    "next": "16.2.10",
    "next-themes": "0.4.6",
    "posthog-js": "1.404.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "remark": "15.0.1",
    "remark-gfm": "4.0.1",
    "remark-rehype": "11.1.2",
    "sonner": "2.0.7",
    "zod": "4.4.3"
